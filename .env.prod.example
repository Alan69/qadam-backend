# ─────────────────────────────────────────────────────────────────────────────
# Production .env — заполните и переименуйте в .env на сервере.
# НЕ коммитьте этот файл с реальными значениями.
# ─────────────────────────────────────────────────────────────────────────────

# Django
DJANGO_SETTINGS_MODULE=config.settings.prod
SECRET_KEY=GENERATE-NEW-VIA-python-c-import-secrets-print-secrets-token-urlsafe-50
DEBUG=False
ALLOWED_HOSTS=api.qadam-app.kz

# Домен для Caddy (используется в Caddyfile через {$DOMAIN})
DOMAIN=api.qadam-app.kz

# Database (Docker postgres сервис)
POSTGRES_DB=qadam
POSTGRES_USER=qadam
POSTGRES_PASSWORD=CHANGE-ME-strong-random-password
DATABASE_URL=postgres://qadam:CHANGE-ME-strong-random-password@postgres:5432/qadam

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# JWT
JWT_ACCESS_LIFETIME_MINUTES=15
JWT_REFRESH_LIFETIME_DAYS=30

# OTP
OTP_TTL_SECONDS=300
OTP_LENGTH=6
OTP_REQUEST_RATE_LIMIT=3
OTP_REQUEST_RATE_WINDOW_SECONDS=600
OTP_VERIFY_MAX_ATTEMPTS=5
OTP_VERIFY_LOCKOUT_SECONDS=900

VERIFICATION_TOKEN_LIFETIME_MINUTES=10

LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_SECONDS=900

# SMS (на проде нужно настроить реального провайдера WhatsApp Business API)
SMS_PROVIDER=console
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_TEMPLATE_NAME=qadam_otp

# CORS (фронтенд + мобилка)
CORS_ALLOWED_ORIGINS=https://qadam-app.kz,https://www.qadam-app.kz

# Логирование / observability
LOG_LEVEL=INFO
SENTRY_DSN=

# Default language
LANGUAGE_CODE=ru
