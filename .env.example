# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=change-me-in-production-use-django-secret-key-generator
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database
DATABASE_URL=postgres://qadam:qadam@postgres:5432/qadam

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# JWT
JWT_ACCESS_LIFETIME_MINUTES=15
JWT_REFRESH_LIFETIME_DAYS=30

# OTP
OTP_TTL_SECONDS=300
OTP_LENGTH=6
OTP_REQUEST_RATE_LIMIT=3
OTP_REQUEST_RATE_WINDOW_SECONDS=600
OTP_VERIFY_MAX_ATTEMPTS=5
OTP_VERIFY_LOCKOUT_SECONDS=900

# Verification token (intermediate JWT used between OTP-verify and complete-step)
VERIFICATION_TOKEN_LIFETIME_MINUTES=10

# Login throttle
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_SECONDS=900

# SMS provider (console | whatsapp)
SMS_PROVIDER=console
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_TEMPLATE_NAME=qadam_otp

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging / observability
LOG_LEVEL=INFO
SENTRY_DSN=

# Default language
LANGUAGE_CODE=ru
